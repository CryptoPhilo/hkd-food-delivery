# ============================================
# 한경배달(HKD) 로컬 개발 환경 설정
# ============================================
# 이 파일을 .env로 복사하여 실제 값을 입력하세요:
#   cp .env.example .env

# --- 서버 ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
REQUEST_TIMEOUT_MS=30000

# --- 데이터베이스 ---
DATABASE_URL="postgresql://hkd_dev:hkd_dev_password@localhost:5432/hkd_delivery_dev"

# --- Redis (미설정 시 인메모리 폴백 자동 동작) ---
# REDIS_URL=redis://localhost:6379

# --- 인증 ---
JWT_SECRET="local-dev-only-do-not-use-in-production"
JWT_REFRESH_SECRET="local-dev-only-refresh-do-not-use"
ADMIN_API_KEY="local-dev-only-admin-key"

# --- SMS (Aligo) ---
ALIGO_API_KEY=""
ALIGO_USER_ID=""
ALIGO_SENDER=""

# --- 결제 (PortOne/아임포트) ---
PORTONE_API_KEY=""
PORTONE_API_SECRET=""
PORTONE_MERCHANT_ID=""
PORTONE_WEBHOOK_SECRET=""

# --- 지도 서비스 ---
KAKAO_REST_API_KEY=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# --- 푸시 알림 (Firebase FCM) ---
# FCM_SERVER_KEY=

# --- AI 이미지 생성 ---
IMAGE_PROVIDER_ORDER="pollinations,together"

# --- Supabase Storage (이미지 저장) ---
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_STORAGE_BUCKET="menu-images"

# --- 웹훅 인증 ---
# Naver Sync 웹훅 HMAC 시크릿 (openssl rand -hex 32 으로 생성)
NAVER_SYNC_WEBHOOK_SECRET=""
# SMS 웹훅 HMAC 시크릿 (openssl rand -hex 32 으로 생성)
SMS_WEBHOOK_SECRET=""

# --- 외부 알림 (선택) ---
# SLACK_WEBHOOK_URL=
# NOTIFICATION_WEBHOOK_URL=
