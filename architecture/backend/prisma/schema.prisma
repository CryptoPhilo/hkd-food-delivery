// ============================================
// 한경 음식배달 서비스 - Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================
// StoreType: "restaurant" | "convenience_store"
// AgeRestriction: "none" | "teen" | "adult"
// Note: SQLite doesn't support enums, using String with validation
// ============================================

// ============================================
// Users Table - 고객 정보
// ============================================
model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?  @unique
  password  String?
  fcmToken  String?  @map("fcm_token")
  isActive  Boolean  @default(true) @map("is_active")
  
  orders           Order[]
  ageVerifications AgeVerification[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([phone])
  @@map("users")
}

// ============================================
// Restaurants Table - 식당 정보
// ============================================
model Restaurant {
  id              String   @id @default(uuid())
  naverPlaceId    String?  @unique @map("naver_place_id")
  kakaoPlaceId    String?  @map("kakao_place_id")
  
  storeType       String   @default("restaurant") @map("store_type") // "restaurant" | "convenience_store"
  
  name            String
  address         String
  roadAddress     String?  @map("road_address")
  latitude        Float
  longitude       Float
  
  phone           String?
  category        String?
  businessStatus  String?  @map("business_status")
  businessHours   String?  @map("business_hours")
  
  description     String?
  imageUrl        String?  @map("image_url")
  rating          Float?
  
  isActive        Boolean  @default(true) @map("is_active")
  isDeliverable   Boolean  @default(true) @map("is_deliverable")
  
  deliveryRadius  Float?   @default(3.0) @map("delivery_radius")
  
  // 편의점 전용 필드
  brandName        String?   @map("brand_name")        // 브랜드명 (CU, GS25 등)
  operatingHours24 Boolean?  @default(false) @map("operating_hours_24") // 24시간 영업
  
  menus           Menu[]
  orders          Order[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([naverPlaceId])
  @@index([storeType])
  @@index([isActive, isDeliverable])
  @@index([latitude, longitude])
  @@map("restaurants")
}

// ============================================
// Menus Table - 메뉴 정보
// ============================================
model Menu {
  id            String   @id @default(uuid())
  restaurantId  String   @map("restaurant_id")
  
  naverMenuId   String?  @map("naver_menu_id")
  name          String
  description   String?
  price         Int
  imageUrl      String?  @map("image_url")
  
  isAvailable   Boolean  @default(true) @map("is_available")
  isActive      Boolean  @default(true) @map("is_active")
  
  // NEW: 편의점 상품 및 성인 인증 필드
  requiresAgeVerification Boolean  @default(false) @map("requires_age_verification")
  ageRestriction          String   @default("none") @map("age_restriction") // "none" | "teen" | "adult"
  category                String?  // 카테고리 (음료, 과자, 주류 등)
  barcode                 String?  // 바코드
  stock                   Int?     // 재고 (편의점용)
  
  orderItems    OrderItem[]
  
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([restaurantId, isAvailable])
  @@index([category])
  @@index([requiresAgeVerification])
  @@map("menus")
}

// ============================================
// Orders Table - 주문 정보
// ============================================
model Order {
  id                    String   @id @default(uuid())
  orderNumber           String   @unique @map("order_number")
  userId                String   @map("user_id")
  restaurantId          String   @map("restaurant_id")
  driverId              String?  @map("driver_id")
  
  status                String   @default("pending")
  subtotal              Int      @default(0)
  deliveryFee           Int      @default(0) @map("delivery_fee")
  totalAmount           Int      @default(0) @map("total_amount")
  deliveryAddress       String   @map("delivery_address")
  deliveryLatitude      Float    @default(0) @map("delivery_latitude")
  deliveryLongitude     Float    @default(0) @map("delivery_longitude")
  
  estimatedPickupTime   DateTime? @map("estimated_pickup_time")
  estimatedDeliveryTime Int?      @map("estimated_delivery_time")
  
  paymentMethod         String?   @map("payment_method")
  customerPaymentId     String?   @map("customer_payment_id")
  customerPaidAt        DateTime? @map("customer_paid_at")
  paymentStatus         String    @default("pending") @map("payment_status")
  
  restaurantPaidAmount  Int?      @map("restaurant_paid_amount")
  restaurantPaidAt      DateTime? @map("restaurant_paid_at")
  
  pickupTime            DateTime? @map("pickup_time")
  confirmToken          String?   @unique @map("confirm_token")
  confirmTokenExpiry    DateTime? @map("confirm_token_expiry")
  confirmedAt           DateTime? @map("confirmed_at")
  pickedUpAt            DateTime? @map("picked_up_at")
  deliveredAt           DateTime? @map("delivered_at")
  cancelledAt           DateTime? @map("cancelled_at")
  cancelReason          String?   @map("cancel_reason")
  
  customerMemo          String?   @map("customer_memo")
  restaurantMemo        String?   @map("restaurant_memo")
  
  user                  User           @relation(fields: [userId], references: [id])
  restaurant            Restaurant     @relation(fields: [restaurantId], references: [id])
  driver                Driver?        @relation(fields: [driverId], references: [id])
  items                 OrderItem[]
  settlementItems       SettlementItem[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([restaurantId])
  @@index([driverId])
  @@index([status])
  @@index([orderNumber])
  @@index([confirmToken])
  @@map("orders")
}

// ============================================
// OrderItems Table - 주문 메뉴 상세
// ============================================
model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  menuId      String? @map("menu_id")
  
  menuName    String  @map("menu_name")
  quantity    Int
  unitPrice   Int     @map("unit_price")
  subtotal    Int
  
  // NEW: 성인 인증 추적
  requiresVerification Boolean?  @default(false) @map("requires_verification")
  verifiedAt           DateTime? @map("verified_at")
  
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu        Menu?   @relation(fields: [menuId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_items")
}

// ============================================
// Settings Table - 시스템 설정
// ============================================
model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String
  description String?
   
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key, type])
  @@map("settings")
}

// ============================================
// DeliveryZone Table - 식당별 배달 가능 지역
// ============================================
model DeliveryZone {
  id            String   @id @default(uuid())
  restaurantId  String   @map("restaurant_id")
  zoneName      String   @map("zone_name")
  latitude      Float
  longitude     Float
  radiusKm      Float    @map("radius_km")
  
  isActive      Boolean  @default(true) @map("is_active")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([restaurantId, zoneName])
  @@index([restaurantId])
  @@map("delivery_zones")
}

// ============================================
// Driver Table - 배달원
// ============================================
model Driver {
  id            String   @id @default(uuid())
  phone         String   @unique
  name          String?
  cardNumber    String?  @map("card_number")
  
  isOnDuty      Boolean  @default(false) @map("is_on_duty")
  dutyStartedAt DateTime? @map("duty_started_at")
  dutyEndedAt   DateTime? @map("duty_ended_at")
  
  totalDeliveries    Int      @default(0) @map("total_deliveries")
  totalDeliveryFee   Int      @default(0) @map("total_delivery_fee")
  
  bankName      String?  @map("bank_name")
  bankAccount   String?  @map("bank_account")
  accountHolder String?  @map("account_holder")
  
  orders        Order[]
  settlements   Settlement[]
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([phone])
  @@index([isOnDuty])
  @@map("drivers")
}

// ============================================
// Settlement Table - 정산
// ============================================
model Settlement {
  id              String   @id @default(uuid())
  driverId        String   @map("driver_id")
  driver          Driver   @relation(fields: [driverId], references: [id])
  
  period          String   @map("period")
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  
  totalDeliveries Int      @map("total_deliveries")
  totalDeliveryFee Int     @map("total_delivery_fee")
  
  serviceFeeRate  Float    @map("service_fee_rate")
  serviceFee      Int      @map("service_fee")
  taxRate         Float    @map("tax_rate")
  tax             Int      @map("tax")
  
  bonus           Int      @default(0) @map("bonus")
  penalty         Int      @default(0) @map("penalty")
  
  grossAmount     Int      @map("gross_amount")
  netAmount       Int      @map("net_amount")
  
  status          String   @default("calculated")
  
  paidAt          DateTime? @map("paid_at")
  paidAmount      Int?      @map("paid_amount")
  
  notes           String?
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  
  items           SettlementItem[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@unique([driverId, period])
  @@index([driverId])
  @@index([period])
  @@index([status])
  @@map("settlements")
}

// ============================================
// SettlementItem Table - 정산 상세
// ============================================
model SettlementItem {
  id            String     @id @default(uuid())
  settlementId  String     @map("settlement_id")
  settlement    Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  
  orderId       String     @map("order_id")
  order         Order      @relation(fields: [orderId], references: [id])
  
  deliveryFee   Int        @map("delivery_fee")
  deliveredAt   DateTime   @map("delivered_at")
  
  createdAt     DateTime   @default(now()) @map("created_at")
  
  @@index([settlementId])
  @@index([orderId])
  @@map("settlement_items")
}

// ============================================
// AgeVerification Table - 성인 인증 기록
// ============================================
model AgeVerification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  
  verifiedAt  DateTime @default(now()) @map("verified_at")
  expiresAt   DateTime @map("expires_at")
  
  method      String   @default("phone") @map("method") // 인증 방식 (phone, ipin 등)
  phoneNumber String   @map("phone_number")
  isVerified  Boolean  @default(true) @map("is_verified")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([expiresAt])
  @@map("age_verifications")
}
